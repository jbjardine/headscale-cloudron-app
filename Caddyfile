:8080 {
	redir / /web/ 302

	@uiApiKeyMutation {
		path /web/api/v1/apikey*
		method POST PUT PATCH DELETE
	}

	handle @uiApiKeyMutation {
		respond "Headscale API key management is disabled in the browser UI" 403
	}

	handle /web/api/* {
		uri strip_prefix /web
		reverse_proxy 127.0.0.1:8081 {
			header_up Authorization "Bearer {$HEADSCALE_UI_API_KEY}"
		}
	}

	handle /web/config.js {
		root * /run/headscale-ui
		header Cache-Control "no-store"
		rewrite * /config.js
		file_server
	}

	handle_path /web* {
		root * /app/code/ui/web
		try_files {path} /index.html
		file_server
	}

	reverse_proxy * 127.0.0.1:8081
}
